{
  "manifest_version": 3,
  "name": "Claude Usage",
  "version": "1.1.0",
  "description": "Monitor Claude Pro usage (5-hour window and weekly) from your toolbar",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["https://claude.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
